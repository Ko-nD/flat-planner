# Унифицируем переносы строк для всех контрибьюторов.
# Все текстовые файлы — LF в репо, локально может быть любой EOL.
* text=auto eol=lf

# Windows-специфичные скрипты — оставляем CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Бинарные файлы — не трогать
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
